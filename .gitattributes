# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always use LF line endings
*.sh text eol=lf
docker-entrypoint.sh text eol=lf

# Batch scripts must always use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Python files
*.py text eol=lf
*.pyi text eol=lf

# Dockerfiles
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf

# Configuration files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf
.env* text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.gz binary
*.zip binary
*.7z binary
*.tar binary